<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="OpenUtau.App.Views.MixFxDialog"
        Icon="/Assets/open-utau.ico"
        Title="{DynamicResource mixfx.caption}"
        Width="640" Height="540"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Window.Styles>
    <Style Selector="TextBlock.lbl">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    <Style Selector="TextBlock.val">
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontFamily" Value="monospace"/>
      <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <Style Selector="Slider">
      <Setter Property="Margin" Value="0,-2,0,-2"/>
    </Style>
    <Style Selector="Border.column">
      <Setter Property="Padding" Value="10"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
      <Setter Property="CornerRadius" Value="3"/>
    </Style>
  </Window.Styles>
  <Border Margin="{Binding $parent.WindowDecorationMargin}">
    <DockPanel Margin="14" LastChildFill="True">

      <!-- TOP: title + enable + recommended -->
      <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,10">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"
                   Text="{Binding TrackName}"/>
        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <TextBlock Grid.Column="2" Classes="lbl" Text="{DynamicResource mixfx.enabled}" Margin="0,0,12,0"/>
        <Button Grid.Column="3" Content="{DynamicResource mixfx.recommended}"
                Command="{Binding ApplyRecommendedCommand}"
                ToolTip.Tip="{DynamicResource mixfx.recommended.tip}"/>
      </Grid>

      <!-- LIBRARY row -->
      <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,10">
        <TextBlock Grid.Column="0" Classes="lbl" Margin="0,0,8,0"
                   Text="{DynamicResource mixfx.library}"/>
        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding UserPresets}" SelectedItem="{Binding SelectedUserPreset}"
                  PlaceholderText="{DynamicResource mixfx.library.placeholder}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Column="2" Margin="6,0,0,0" Content="{DynamicResource mixfx.library.save}"
                Command="{Binding SaveUserPresetCommand}"/>
        <Button Grid.Column="3" Margin="6,0,0,0" Content="{DynamicResource mixfx.library.delete}"
                Command="{Binding DeleteUserPresetCommand}"
                IsEnabled="{Binding CanDeleteSelectedPreset}"/>
      </Grid>

      <!-- BOTTOM: export checkbox + OK/Cancel -->
      <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,10,0,0">
        <CheckBox Grid.Column="0" IsChecked="{Binding ApplyOnExportMixdown}" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Classes="lbl" Margin="0,0,12,0" Text="{DynamicResource mixfx.applyonexport}"/>
        <Button Grid.Column="3" Content="{DynamicResource button.cancel}"
                MinWidth="70" Margin="0,0,8,0" Click="OnCancelClicked"/>
        <Button Grid.Column="4" Content="{DynamicResource button.ok}"
                MinWidth="70" Click="OnOkClicked"/>
      </Grid>

      <!-- BODY: 3 columns side by side -->
      <Grid ColumnDefinitions="*,8,*,8,*" IsEnabled="{Binding Enabled}">

        <!-- EQ -->
        <Border Grid.Column="0" Classes="column">
          <StackPanel Spacing="3">
            <TextBlock Classes="section" Text="EQ"/>
            <ComboBox HorizontalAlignment="Stretch" Margin="0,0,0,4"
                      ItemsSource="{Binding EqPresets}" SelectedItem="{Binding SelectedEq}"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Low (dB)"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding EqLowDb, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
            </Grid>
            <Slider Minimum="-12" Maximum="12" Value="{Binding EqLowDb}" TickFrequency="0.5"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Mid Freq"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding EqMidFreq, StringFormat={}{0:F0} Hz}"/>
            </Grid>
            <Slider Minimum="200" Maximum="6000" Value="{Binding EqMidFreq}" TickFrequency="50"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Mid (dB)"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding EqMidDb, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
            </Grid>
            <Slider Minimum="-12" Maximum="12" Value="{Binding EqMidDb}" TickFrequency="0.5"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="High (dB)"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding EqHighDb, StringFormat={}{0:+0.0;-0.0;0.0}}"/>
            </Grid>
            <Slider Minimum="-12" Maximum="12" Value="{Binding EqHighDb}" TickFrequency="0.5"/>
          </StackPanel>
        </Border>

        <!-- Compressor -->
        <Border Grid.Column="2" Classes="column">
          <StackPanel Spacing="3">
            <TextBlock Classes="section" Text="Compressor"/>
            <ComboBox HorizontalAlignment="Stretch" Margin="0,0,0,4"
                      ItemsSource="{Binding CompPresets}" SelectedItem="{Binding SelectedComp}"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Threshold"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding CompThresholdDb, StringFormat={}{0:F1} dB}"/>
            </Grid>
            <Slider Minimum="-40" Maximum="0" Value="{Binding CompThresholdDb}" TickFrequency="1"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Ratio"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding CompRatio, StringFormat={}{0:F1}:1}"/>
            </Grid>
            <Slider Minimum="1" Maximum="20" Value="{Binding CompRatio}" TickFrequency="0.1"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Makeup"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding CompMakeupDb, StringFormat={}{0:F1} dB}"/>
            </Grid>
            <Slider Minimum="0" Maximum="12" Value="{Binding CompMakeupDb}" TickFrequency="0.1"/>
          </StackPanel>
        </Border>

        <!-- Reverb -->
        <Border Grid.Column="4" Classes="column">
          <StackPanel Spacing="3">
            <TextBlock Classes="section" Text="Reverb"/>
            <ComboBox HorizontalAlignment="Stretch" Margin="0,0,0,4"
                      ItemsSource="{Binding ReverbPresets}" SelectedItem="{Binding SelectedReverb}"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Size"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding ReverbSize, StringFormat={}{0:F2}}"/>
            </Grid>
            <Slider Minimum="0" Maximum="1" Value="{Binding ReverbSize}" TickFrequency="0.01"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Damp"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding ReverbDamp, StringFormat={}{0:F2}}"/>
            </Grid>
            <Slider Minimum="0" Maximum="1" Value="{Binding ReverbDamp}" TickFrequency="0.01"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Wet"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding ReverbWet, StringFormat={}{0:F2}}"/>
            </Grid>
            <Slider Minimum="0" Maximum="2" Value="{Binding ReverbWet}" TickFrequency="0.01"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="lbl" Text="Pre-Delay"/>
              <TextBlock Grid.Column="1" Classes="val" Text="{Binding ReverbPreDelayMs, StringFormat={}{0:F0} ms}"/>
            </Grid>
            <Slider Minimum="0" Maximum="200" Value="{Binding ReverbPreDelayMs}" TickFrequency="1"/>
          </StackPanel>
        </Border>

      </Grid>
    </DockPanel>
  </Border>
</Window>
